generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

// Supabase: DATABASE_URL = pooler (6543), DIRECT_URL = direct (5432). Local Postgres: set both to the same URL.
datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Users ──────────────────────────────────────────────────────────────────────

model User {
  id             String    @id @default(uuid()) @db.Uuid
  email          String    @unique @db.VarChar(255)
  passwordHash   String    @map("password_hash") @db.VarChar(255)
  firstName      String    @map("first_name") @db.VarChar(100)
  lastName       String    @map("last_name") @db.VarChar(100)
  phone          String?   @db.VarChar(20)
  avatarUrl      String?   @map("avatar_url") @db.VarChar(500)
  role           String    @default("renter") @db.VarChar(20)
  emailVerified  Boolean   @default(false) @map("email_verified")
  phoneVerified  Boolean   @default(false) @map("phone_verified")
  fcmToken       String?   @map("fcm_token") @db.VarChar(500)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  lastLoginAt    DateTime? @map("last_login_at")
  isActive       Boolean   @default(true) @map("is_active")

  listings             Listing[]
  sentMessages         Message[]          @relation("SentMessages")
  conversationsAsOne   Conversation[]     @relation("ParticipantOne")
  conversationsAsTwo   Conversation[]     @relation("ParticipantTwo")
  visitsAsRenter       Visit[]            @relation("RenterVisits")
  visitsAsLandlord     Visit[]            @relation("LandlordVisits")
  reviews              Review[]
  reports              Report[]           @relation("Reporter")
  resolvedReports      Report[]           @relation("Resolver")
  moverProfile         Mover?
  moverBookings        MoverBooking[]
  favorites            Favorite[]

  @@index([email])
  @@index([role])
  @@map("users")
}

// ─── Listings ───────────────────────────────────────────────────────────────────

model Listing {
  id              String    @id @default(uuid()) @db.Uuid
  landlordId      String    @map("landlord_id") @db.Uuid
  title           String    @db.VarChar(100)
  description     String?   @db.Text
  propertyType    String    @map("property_type") @db.VarChar(50)
  address         String    @db.VarChar(500)
  city            String    @db.VarChar(100)
  state           String?   @db.VarChar(100)
  zipCode         String?   @map("zip_code") @db.VarChar(20)
  country         String    @default("USA") @db.VarChar(100)
  latitude        Decimal?  @db.Decimal(10, 8)
  longitude       Decimal?  @db.Decimal(11, 8)
  bedrooms        Int
  bathrooms       Decimal?  @db.Decimal(3, 1)
  squareFootage   Int?      @map("square_footage")
  monthlyRent     Decimal   @map("monthly_rent") @db.Decimal(10, 2)
  deposit         Decimal?  @db.Decimal(10, 2)
  availableFrom   DateTime? @map("available_from") @db.Date
  amenities       Json      @default("[]")
  status          String    @default("active") @db.VarChar(20)
  isFeatured      Boolean   @default(false) @map("is_featured")
  virtualTourUrl  String?   @map("virtual_tour_url") @db.VarChar(500)
  viewsCount      Int       @default(0) @map("views_count")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  landlord       User             @relation(fields: [landlordId], references: [id])
  images         ListingImage[]
  conversations  Conversation[]
  visits         Visit[]
  reviews        Review[]
  reports        Report[]
  moverBookings  MoverBooking[]
  favorites      Favorite[]

  @@index([landlordId])
  @@index([city])
  @@index([status])
  @@index([latitude, longitude])
  @@index([monthlyRent])
  @@map("listings")
}

model ListingImage {
  id            String   @id @default(uuid()) @db.Uuid
  listingId     String   @map("listing_id") @db.Uuid
  url           String   @db.VarChar(500)
  thumbnailUrl  String?  @map("thumbnail_url") @db.VarChar(500)
  position      Int      @default(0)
  isVirtualTour Boolean  @default(false) @map("is_virtual_tour")
  createdAt     DateTime @default(now()) @map("created_at")

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@map("listing_images")
}

// ─── Conversations & Messages ───────────────────────────────────────────────────

model Conversation {
  id               String    @id @default(uuid()) @db.Uuid
  listingId        String    @map("listing_id") @db.Uuid
  participantOneId String    @map("participant_one_id") @db.Uuid
  participantTwoId String    @map("participant_two_id") @db.Uuid
  lastMessageAt    DateTime? @map("last_message_at")
  createdAt        DateTime  @default(now()) @map("created_at")

  listing        Listing   @relation(fields: [listingId], references: [id])
  participantOne User      @relation("ParticipantOne", fields: [participantOneId], references: [id])
  participantTwo User      @relation("ParticipantTwo", fields: [participantTwoId], references: [id])
  messages       Message[]

  @@unique([participantOneId, participantTwoId, listingId])
  @@map("conversations")
}

model Message {
  id             String   @id @default(uuid()) @db.Uuid
  conversationId String   @map("conversation_id") @db.Uuid
  senderId       String   @map("sender_id") @db.Uuid
  messageType    String   @default("text") @map("message_type") @db.VarChar(20)
  content        String   @db.Text
  mediaUrl       String?  @map("media_url") @db.VarChar(500)
  isRead         Boolean  @default(false) @map("is_read")
  createdAt      DateTime @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("SentMessages", fields: [senderId], references: [id])

  @@index([conversationId])
  @@index([createdAt])
  @@map("messages")
}

// ─── Visits ─────────────────────────────────────────────────────────────────────

model Visit {
  id           String    @id @default(uuid()) @db.Uuid
  listingId    String    @map("listing_id") @db.Uuid
  renterId     String    @map("renter_id") @db.Uuid
  landlordId   String    @map("landlord_id") @db.Uuid
  scheduledAt  DateTime  @map("scheduled_at")
  endAt        DateTime? @map("end_at")
  viewingType  String    @default("in_person") @map("viewing_type") @db.VarChar(20)
  status       String    @default("pending") @db.VarChar(20)
  note         String?   @db.Text
  actualStart  DateTime? @map("actual_start")
  actualEnd    DateTime? @map("actual_end")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  listing  Listing @relation(fields: [listingId], references: [id])
  renter   User    @relation("RenterVisits", fields: [renterId], references: [id])
  landlord User    @relation("LandlordVisits", fields: [landlordId], references: [id])

  @@index([listingId])
  @@index([renterId])
  @@index([status])
  @@map("visits")
}

// ─── Reviews ────────────────────────────────────────────────────────────────────

model Review {
  id                 String    @id @default(uuid()) @db.Uuid
  listingId          String    @map("listing_id") @db.Uuid
  renterId           String    @map("renter_id") @db.Uuid
  overallRating      Int       @map("overall_rating")
  neighborhoodRating Int?      @map("neighborhood_rating")
  noiseRating        Int?      @map("noise_rating")
  maintenanceRating  Int?      @map("maintenance_rating")
  amenitiesRating    Int?      @map("amenities_rating")
  comment            String    @db.Text
  pros               Json      @default("[]")
  cons               Json      @default("[]")
  landlordResponse   String?   @map("landlord_response") @db.Text
  responseAt         DateTime? @map("response_at")
  isVerified         Boolean   @default(false) @map("is_verified")
  createdAt          DateTime  @default(now()) @map("created_at")

  listing Listing @relation(fields: [listingId], references: [id])
  renter  User    @relation(fields: [renterId], references: [id])

  @@index([listingId])
  @@index([overallRating])
  @@map("reviews")
}

// ─── Reports ────────────────────────────────────────────────────────────────────

model Report {
  id           String    @id @default(uuid()) @db.Uuid
  listingId    String    @map("listing_id") @db.Uuid
  reporterId   String    @map("reporter_id") @db.Uuid
  category     String    @db.VarChar(50)
  description  String?   @db.Text
  evidenceUrls Json      @default("[]") @map("evidence_urls")
  status       String    @default("new") @db.VarChar(20)
  adminNotes   String?   @map("admin_notes") @db.Text
  resolvedAt   DateTime? @map("resolved_at")
  resolvedBy   String?   @map("resolved_by") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")

  listing  Listing @relation(fields: [listingId], references: [id])
  reporter User    @relation("Reporter", fields: [reporterId], references: [id])
  resolver User?   @relation("Resolver", fields: [resolvedBy], references: [id])

  @@index([listingId])
  @@index([status])
  @@map("reports")
}

// ─── Movers & Bookings ─────────────────────────────────────────────────────────

model Mover {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @unique @map("user_id") @db.Uuid
  companyName       String   @map("company_name") @db.VarChar(200)
  logoUrl           String?  @map("logo_url") @db.VarChar(500)
  description       String?  @db.Text
  serviceArea       Json     @map("service_area")
  fleetInfo         Json?    @map("fleet_info")
  services          Json
  hourlyRate        Decimal? @map("hourly_rate") @db.Decimal(10, 2)
  fixedPrice        Decimal? @map("fixed_price") @db.Decimal(10, 2)
  insuranceCoverage Decimal? @map("insurance_coverage") @db.Decimal(10, 2)
  availability      Json?
  isVerified        Boolean  @default(false) @map("is_verified")
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  user     User           @relation(fields: [userId], references: [id])
  bookings MoverBooking[]

  @@map("movers")
}

model MoverBooking {
  id              String   @id @default(uuid()) @db.Uuid
  moverId         String   @map("mover_id") @db.Uuid
  renterId        String   @map("renter_id") @db.Uuid
  listingId       String?  @map("listing_id") @db.Uuid
  pickupAddress   String   @map("pickup_address") @db.VarChar(500)
  dropoffAddress  String   @map("dropoff_address") @db.VarChar(500)
  scheduledDate   DateTime @map("scheduled_date") @db.Date
  timeWindowStart DateTime @map("time_window_start") @db.Time()
  timeWindowEnd   DateTime @map("time_window_end") @db.Time()
  services        Json
  estimatedPrice  Decimal  @map("estimated_price") @db.Decimal(10, 2)
  finalPrice      Decimal? @map("final_price") @db.Decimal(10, 2)
  status          String   @default("requested") @db.VarChar(20)
  note            String?  @db.Text
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  mover   Mover    @relation(fields: [moverId], references: [id])
  renter  User     @relation(fields: [renterId], references: [id])
  listing Listing? @relation(fields: [listingId], references: [id])

  @@index([moverId])
  @@index([status])
  @@map("mover_bookings")
}

// ─── Favorites ──────────────────────────────────────────────────────────────────

model Favorite {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  listingId String   @map("listing_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
  @@map("favorites")
}
