# Server
PORT=3000
NODE_ENV=development

# ─── Supabase (primary backend) ───────────────────────────────────────────────
# Project Settings → Database: use "URI" for Prisma. Enable connection pooling (transaction mode) for DATABASE_URL.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Create a public bucket in Storage (e.g. listing-media) for listing images.
SUPABASE_STORAGE_BUCKET=listing-media

# Postgres (Supabase: pooler for app, direct for migrations)
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres:PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# Local Postgres fallback: set both to the same connection string, e.g.
# DATABASE_URL=postgresql://user:pass@localhost:5432/rentas?schema=public
# DIRECT_URL=postgresql://user:pass@localhost:5432/rentas?schema=public

# Redis — required for Bull job queue and refresh token revocation
REDIS_URL=redis://localhost:6379

# JWT (API auth; separate from Supabase Auth)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# AWS S3 (optional — not used when uploading via Supabase Storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=rentas-media

# Firebase (FCM)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY=your-private-key
FIREBASE_CLIENT_EMAIL=your-client-email

# Email (SendGrid)
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@rentas.app

# Mapbox
MAPBOX_ACCESS_TOKEN=your-mapbox-token

# Frontend URL (CORS) — comma-separated list for multiple origins
# e.g. FRONTEND_URL=http://localhost:3001,https://your-app.vercel.app
FRONTEND_URL=http://localhost:3001
